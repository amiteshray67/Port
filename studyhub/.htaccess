# Disable caching for HTML files so LiteSpeed always serves fresh content
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# Allow JS/CSS/images to cache normally
<FilesMatch "\.(js|css|jpg|jpeg|png|gif|pdf|woff|woff2)$">
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>
